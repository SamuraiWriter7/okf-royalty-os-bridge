{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://github.com/SamuraiWriter7/okf-royalty-os-bridge/schemas/agent-consumption-event.schema.json",
"title": "Agent Consumption Event",
"description": "A record describing how an AI agent consumed an OKF-linked knowledge package under Royalty OS governance.",
"type": "object",
"additionalProperties": false,
"required": ["agent_consumption_event"],
"properties": {
"agent_consumption_event": {
"type": "object",
"additionalProperties": false,
"required": [
"schema_version",
"id",
"created_at",
"agent",
"consumed_asset",
"policy_context",
"consumption",
"trace_context",
"output_context",
"usage_logging",
"review"
],
"properties": {
"schema_version": {
"type": "string",
"const": "0.5.0"
},
"id": {
"type": "string",
"minLength": 1
},
"created_at": {
"type": "string",
"format": "date-time"
},
"agent": {
"type": "object",
"additionalProperties": false,
"required": ["agent_id", "agent_type", "agent_name"],
"properties": {
"agent_id": {
"type": "string",
"minLength": 1
},
"agent_type": {
"type": "string",
"enum": [
"llm_agent",
"retrieval_agent",
"workflow_agent",
"indexer",
"human_assisted_agent",
"other"
]
},
"agent_name": {
"type": "string",
"minLength": 1
},
"operator": {
"type": "string"
}
}
},
"consumed_asset": {
"type": "object",
"additionalProperties": false,
"required": ["okf_document", "bridge_record", "policy_integration", "trace_links"],
"properties": {
"okf_document": {
"type": "object",
"additionalProperties": false,
"required": ["path", "okf_type", "title"],
"properties": {
"path": {
"type": "string",
"minLength": 1
},
"okf_type": {
"type": "string",
"minLength": 1
},
"title": {
"type": "string",
"minLength": 1
},
"content_hash": {
"type": "string"
}
}
},
"bridge_record": {
"type": "object",
"additionalProperties": false,
"required": ["bridge_id", "ref", "schema_version"],
"properties": {
"bridge_id": {
"type": "string",
"minLength": 1
},
"ref": {
"type": "string",
"minLength": 1
},
"schema_version": {
"type": "string",
"minLength": 1
}
}
},
"policy_integration": {
"type": "object",
"additionalProperties": false,
"required": ["policy_integration_id", "ref", "schema_version"],
"properties": {
"policy_integration_id": {
"type": "string",
"minLength": 1
},
"ref": {
"type": "string",
"minLength": 1
},
"schema_version": {
"type": "string",
"minLength": 1
}
}
},
"trace_links": {
"type": "array",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": ["link_id", "link_type", "status"],
"properties": {
"link_id": {
"type": "string",
"minLength": 1
},
"link_type": {
"type": "string",
"enum": [
"okf_to_bridge",
"bridge_to_origin_trace",
"bridge_to_evidence_trace",
"bridge_to_attribution_trace",
"bridge_to_usage_trace",
"resource_to_evidence",
"timestamp_to_lifecycle"
]
},
"status": {
"type": "string",
"enum": [
"candidate",
"review",
"active",
"rejected",
"deprecated"
]
}
}
}
}
}
},
"policy_context": {
"type": "object",
"additionalProperties": false,
"required": [
"policy_id",
"enforcement_mode",
"deny_if_no_policy",
"decision_snapshot"
],
"properties": {
"policy_id": {
"type": "string",
"minLength": 1
},
"enforcement_mode": {
"type": "string",
"enum": [
"advisory",
"audit_only",
"review_gate",
"blocking"
]
},
"deny_if_no_policy": {
"type": "boolean"
},
"decision_snapshot": {
"type": "array",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"action",
"decision",
"rule_id",
"human_review_required"
],
"properties": {
"action": {
"type": "string",
"enum": [
"read",
"index",
"embed",
"retrieve",
"reason",
"generate",
"train",
"fine_tune",
"redistribute"
]
},
"decision": {
"type": "string",
"enum": [
"permit",
"deny",
"review_required"
]
},
"rule_id": {
"type": "string",
"minLength": 1
},
"human_review_required": {
"type": "boolean"
},
"evidence_required": {
"type": "boolean"
}
}
}
}
}
},
"consumption": {
"type": "object",
"additionalProperties": false,
"required": [
"event_type",
"purpose",
"performed_at",
"permitted",
"blocked"
],
"properties": {
"event_type": {
"type": "string",
"enum": [
"read",
"index",
"embed",
"retrieve",
"reason",
"generate",
"train",
"fine_tune",
"redistribute"
]
},
"purpose": {
"type": "string",
"minLength": 1
},
"performed_at": {
"type": "string",
"format": "date-time"
},
"input_refs": {
"type": "array",
"items": {
"type": "string"
}
},
"permitted": {
"type": "boolean"
},
"blocked": {
"type": "boolean"
},
"block_reason": {
"type": "string"
}
}
},
"trace_context": {
"type": "object",
"additionalProperties": false,
"required": [
"source_trace_ids",
"generated_usage_trace_id",
"attribution_required",
"allocation_triggered"
],
"properties": {
"source_trace_ids": {
"type": "array",
"items": {
"type": "string"
}
},
"generated_usage_trace_id": {
"type": "string",
"minLength": 1
},
"attribution_required": {
"type": "boolean"
},
"allocation_triggered": {
"type": "boolean"
}
}
},
"output_context": {
"type": "object",
"additionalProperties": false,
"required": [
"output_generated",
"attribution_note_required"
],
"properties": {
"output_generated": {
"type": "boolean"
},
"output_ref": {
"type": "string"
},
"output_hash": {
"type": "string"
},
"attribution_note_required": {
"type": "boolean"
}
}
},
"usage_logging": {
"type": "object",
"additionalProperties": false,
"required": ["log_required", "log_status"],
"properties": {
"log_required": {
"type": "boolean"
},
"log_status": {
"type": "string",
"enum": [
"pending",
"recorded",
"skipped",
"failed"
]
},
"usage_event_ref": {
"type": "string"
}
}
},
"review": {
"type": "object",
"additionalProperties": false,
"required": ["review_required", "review_status"],
"properties": {
"review_required": {
"type": "boolean"
},
"review_status": {
"type": "string",
"enum": [
"pending",
"approved",
"rejected",
"not_required"
]
},
"review_note": {
"type": "string"
}
}
}
}
}
}
}
